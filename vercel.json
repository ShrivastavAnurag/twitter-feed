{
  "crons": [
    {
      "path": "/api/scrape",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "api/scrape.py": {
      "maxDuration": 300
    },
    "api/tweets.py": {
      "maxDuration": 15
    },
    "api/status.py": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" }
  ]
}
